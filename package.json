{
  "name": "codex-studio",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "description": "AI-native development environment",
  "main": "./out/main/index.js",
  "author": {
    "name": "Codex Studio",
    "email": "codex-studio@users.noreply.github.com"
  },
  "dependencies": {
    "@codex/cli": "workspace:*",
    "node-pty": "^1.1.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "pnpm build && playwright test",
    "test:benchmark": "vitest run tests/agent-benchmark.test.ts",
    "cli": "tsx packages/cli/src/cli.ts",
    "postinstall": "electron-rebuild -f -w node-pty && node scripts/patch-electron-name.mjs",
    "patch:electron-name": "node scripts/patch-electron-name.mjs",
    "package": "pnpm build && electron-builder",
    "package:mac": "pnpm build && electron-builder --mac",
    "package:win": "pnpm build && electron-builder --win",
    "package:linux": "pnpm build && electron-builder --linux"
  },
  "bin": {
    "codex-studio": "./packages/cli/bin/codex-studio.mjs"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.2.0",
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.29",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/coverage-v8": "^3.2.7",
    "electron": "^35.5.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "tsx": "^4.19.4",
    "vite": "^6.0.0",
    "vitest": "^3.2.1"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.4.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild",
      "node-pty"
    ]
  }
}
